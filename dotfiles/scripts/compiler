#!/bin/sh
# compiler — compile or run documents based on file extension.
# Usage: compiler <file>
#
# Supported extensions:
#   .tex       LaTeX (via latexmk)
#   .mom/.ms   groff mom/ms macros → PDF
#   .md        Markdown → PDF (lowdown/groffdown/pandoc)
#   .org       Org-mode → PDF (emacs batch)
#   .rmd/.Rmd  R Markdown → PDF
#   .c/.cpp    C/C++ → compile + run
#   .go        Go → run
#   .java      Java → compile + run
#   .py        Python → run
#   .rs        Rust → cargo build
#   .scad      OpenSCAD → STL
#   .sass      Sass → CSS
#   .sent      Open as presentation
#   [0-9]      man page → PDF
#   *          Run via shebang

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    sed -n '2,20p' "$0" | sed 's/^# //; s/^#$//'
    exit 0
fi

file="${1}"
ext="${file##*.}"
dir=${file%/*}
base="${file%.*}"

cd "${dir}" || exit 1

case "${ext}" in
    [0-9]) preconv "${file}" | refer -PS -e | groff -mandoc -T pdf > "${base}.pdf" ;;
    mom|ms) preconv "${file}" | refer -PS -e | groff -T pdf -m"${ext}" > "${base}.pdf" ;;
    c) cc "${file}" -o "${base}" && "./${base}" ;;
    cob) cobc -x -o "$base" "$file" && "$base" ;;
    cpp) g++ "${file}" -o "${base}" && "./${base}" ;;
    cs) mcs "${file}" && mono "${base}.exe" ;;
    go) go run "${file}" ;;
    h) sudo make install ;;
    java) javac -d classes "${file}" && java -cp classes "${base}" ;;
    m) octave "${file}" ;;
    md) [ -x "$(command -v lowdown)" ] && \
	    lowdown --parse-no-intraemph "${file}" -Tms | groff -mpdfmark -ms -kept -T pdf > "${base}.pdf" || \
	    [ -x "$(command -v groffdown)" ] && \
	    groffdown -i "${file}" | groff -T pdf > "${base}.pdf" || \
	    pandoc -t ms --highlight-style="kate" -s -o "${base}.pdf" "${file}" ;;
    org) emacs "${file}" --batch -u "${USER}" -f org-latex-export-to-pdf 2>/dev/null ;;
    py) python "${file}" ;;
    rink) rink -f "${file}" ;;
    [rR]md) Rscript -e "rmarkdown::render('${file}', quiet=TRUE)" ;;
    rs) cargo build ;;
    sass) sassc -a "${file}" "${base}.css" ;;
    scad) openscad -o "${base}.stl" "${file}" ;;
    sent) setsid -f sent "${file}" 2> "/dev/null" ;;
    tex)
            out=$(latexmk -g -latexoption="-halt-on-error" "${file}" 2>&1) || \
            printf "%s\n" "$out" | awk '
                /^!/ { show=1 }
                /^[ \t]*[0-9]+ words of node memory/ || /^!  ==> Fatal error/ || /^Latexmk:/ { show=0 }
                show && !/^See the LaTeX manual/ && !/^Type  H <return>/ && !/^ \.\.\./ && !/^$/ { print }
            ' ;;
    R) Rscript "${file}" ;;
    *) sed -n '/^#!/s/^#!//p; q' "${file}" | xargs -r -I % "${file}" ;;
esac
