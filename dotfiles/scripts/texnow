#!/bin/sh
# texnow — create a new LaTeX project from template and open in nvim.
# Usage: texnow [name] [-h|--help] [--standalone] [-l|--lualatex] [-x|--xelatex]
#
# Creates ~/Documents/texnow/<name>/ with template.tex, .gitignore, and
# a project-local latexmkrc that sets the TeX engine (default: pdflatex).
# Use -l for lualatex, -x for xelatex.  Then opens the .tex file in nvim.
# If no name is given, a timestamp is used (YYYYMMDDHHMMSS).
#
# leopard.sty is NOT copied — it is found via TEXINPUTS pointing to
# the canonical copy at ~/Documents/texnow/leopard.sty.
# Use --standalone to copy leopard.sty for portable projects.
#
# The project-local latexmkrc overrides the global ~/.config/latexmk/latexmkrc.
# latexmk reads project-local rc files last, so $pdf_mode here always wins.
# vimtex also parses it for engine detection (when no % !TEX magic comment).

set -eu

TEXNOW_DIR="${HOME}/Documents/texnow"
standalone=false
pdf_mode=1          # default: pdflatex

# --- Parse flags ---
while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help)
            sed -n '2,15p' "$0" | sed 's/^# //; s/^#$//'
            exit 0
            ;;
        --standalone)
            standalone=true
            shift
            ;;
        -l|--lualatex)
            pdf_mode=4
            shift
            ;;
        -x|--xelatex)
            pdf_mode=5
            shift
            ;;
        --*)
            echo "texnow: unknown flag: $1" >&2
            exit 1
            ;;
        *)
            break
            ;;
    esac
done

# --- Resolve project name ---
file="$(date +%Y%m%d%H%M%S)"
[ -n "${1:-}" ] && file="$1"

# --- Validate TEXNOW_DIR ---
if [ ! -d "$TEXNOW_DIR" ]; then
    echo "texnow: $TEXNOW_DIR does not exist — run: mkdir -p $TEXNOW_DIR" >&2
    exit 1
fi

for needed in template.tex .gitignore leopard.sty; do
    if [ ! -f "$TEXNOW_DIR/$needed" ]; then
        echo "texnow: $TEXNOW_DIR/$needed not found" >&2
        exit 1
    fi
done

# --- Create project directory ---
proj_dir="$TEXNOW_DIR/$file"
if [ -d "$proj_dir" ]; then
    echo "texnow: $proj_dir already exists" >&2
    exit 1
fi

mkdir "$proj_dir"

# --- Copy template files ---
cp "$TEXNOW_DIR/template.tex" "$proj_dir/$file.tex"
cp "$TEXNOW_DIR/.gitignore" "$proj_dir/.gitignore"

if $standalone; then
    cp "$TEXNOW_DIR/leopard.sty" "$proj_dir/"
fi

# --- Write project-local latexmkrc (engine choice) ---
case "$pdf_mode" in
    1) engine_name="pdflatex" ;;
    4) engine_name="lualatex" ;;
    5) engine_name="xelatex" ;;
    *) engine_name="pdflatex" ;;
esac
cat > "$proj_dir/latexmkrc" <<EOF
# Project-local latexmk configuration — read after global rc, before CLI flags.
# Generated by texnow (${engine_name}).
\$pdf_mode = $pdf_mode;
EOF

# --- Open in nvim ---
exec nvim "$proj_dir/$file.tex"
