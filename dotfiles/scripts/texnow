#!/bin/sh
# texnow — create a new LaTeX project from template and open in nvim.
# Usage: texnow [name]
#
# Creates ~/Documents/texnow/<name>/ with leopard.sty and template.tex,
# then opens the .tex file in nvim.  If no name is given, a timestamp
# is used (YYYYMMDDHHMMSS).

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    sed -n '2,8p' "$0" | sed 's/^# //; s/^#$//'
    exit 0
fi

file="$(date +%Y%m%d%H%M%S)"

[ -n "$1" ] && file="$1"

mkdir ~/Documents/texnow/"$file"
cd ~/Documents/texnow/$file
cp ../leopard.sty .
cp ../template.tex ./"$file".tex
nvim "$file".tex
