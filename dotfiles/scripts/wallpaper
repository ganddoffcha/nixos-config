#!/usr/bin/env bash
# Wallpaper setter with automatic Catppuccin accent detection.
# Sets wallpaper via hyprpaper, detects the best Catppuccin Mocha accent
# from dominant colours, and applies it live — no rebuild needed.
#
#   wallpaper                list available wallpapers
#   wallpaper <image>        set wallpaper + auto-detect accent (live apply)
#   wallpaper -l             list available wallpapers
#   wallpaper -p <image>     preview dominant colours with accent match
#   wallpaper -h             show this help
#
# State files (imperative, not git-tracked):
#   ~/.config/catppuccin/current-accent       — accent name (e.g. "blue")
#   ~/.config/catppuccin/current-accent-hex   — accent hex (e.g. "89b4fa")
#   ~/.config/catppuccin/current-wallpaper    — wallpaper filename
#   ~/.config/catppuccin/hyprland-accent.conf — sourced by hyprland.conf
#   ~/.config/catppuccin/waybar-accent.css    — NOT consumed (Waybar CSS lacks @import)

set -e

WALLPAPER_DIR="$HOME/dotfiles/wallpapers"
HYPRPAPER_CONF="$HOME/.config/hypr/hyprpaper.conf"
STATE_DIR="$HOME/.config/catppuccin"
ACCENT_FILE="$STATE_DIR/current-accent"
WALLPAPER_FILE="$STATE_DIR/current-wallpaper"
HYPRLAND_ACCENT="$STATE_DIR/hyprland-accent.conf"
WAYBAR_ACCENT="$STATE_DIR/waybar-accent.css"

# Catppuccin Mocha 13 accent colours (hex without #) — declarative palette
declare -A ACCENTS=(
    [rosewater]=f5e0dc  [flamingo]=f2cdcd  [pink]=f5c2e7
    [mauve]=cba6f7      [red]=f38ba8       [maroon]=eba0ac
    [peach]=fab387      [yellow]=f9e2af    [green]=a6e3a1
    [teal]=94e2d5       [sky]=89dceb       [sapphire]=74c7ec
    [blue]=89b4fa       [lavender]=b4befe
)

# ── Extract dominant colours from an image ──────────────────────────────
extract_colors() {
    local image="$1" n="${2:-8}"
    local img="$WALLPAPER_DIR/$image"
    [ -f "$img" ] || img="$image"
    magick "$img" -resize 200x200 -colors 16 -quantize RGB \
        -format "%c" histogram:info:- 2>/dev/null |
        sort -rn | head -n "$n" |
        sed -n 's/.*#\([0-9A-Fa-f]\{6,12\}\).*/\1/p' |
        while read -r hex; do
            echo "${hex:0:6}"
        done
}

# ── RGB colour distance (Euclidean, weighted for human perception) ──────
color_dist() {
    local r1=$((16#${1:0:2})) g1=$((16#${1:2:2})) b1=$((16#${1:4:2}))
    local r2=$((16#${2:0:2})) g2=$((16#${2:2:2})) b2=$((16#${2:4:2}))
    local dr=$(( (r1 - r2) * 3 )) dg=$(( (g1 - g2) * 4 )) db=$(( (b1 - b2) * 2 ))
    echo $(( dr*dr + dg*dg + db*db ))
}

# ── Find best Catppuccin accent for a wallpaper ────────────────────────
best_accent() {
    local image="$1"
    local -a dominant
    while IFS= read -r hex; do dominant+=("$hex"); done < <(extract_colors "$image" 6)

    local best_name="" best_score=99999999
    for name in "${!ACCENTS[@]}"; do
        local accent_hex="${ACCENTS[$name]}"
        local total=0
        for dc in "${dominant[@]}"; do
            local d; d=$(color_dist "$dc" "$accent_hex")
            total=$(( total + d ))
        done
        echo "  $name: $total" >&2
        if [ "$total" -lt "$best_score" ]; then
            best_score=$total
            best_name=$name
        fi
    done
    echo "$best_name"
}

# ── Send command to hyprpaper IPC socket ────────────────────────────────
hyprpaper_ipc() {
    local cmd="$1"
    local sock_dir="$XDG_RUNTIME_DIR/hypr"
    local instance sock
    instance=$(ls "$sock_dir" 2>/dev/null | head -1)
    [ -z "$instance" ] && return 1
    sock="$sock_dir/$instance/.hyprpaper.sock"
    [ -S "$sock" ] || return 1
    python3 -c "
import socket
s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
s.connect('$sock')
s.sendall(b'$cmd')
resp = s.recv(1024)
print(resp.decode().strip())
s.close()
" 2>/dev/null
}

# ── Set wallpaper via hyprpaper IPC (no restart → doesn't disrupt waybar) ─
set_wallpaper() {
    local image="$1"
    local path="$WALLPAPER_DIR/$image"
    [ -f "$path" ] || { echo "Wallpaper not found: $path" >&2; return 1; }

    # Write config for persistence across reboots
    mkdir -p "$(dirname "$HYPRPAPER_CONF")"
    cat > "$HYPRPAPER_CONF" <<EOF
preload = $path
wallpaper = ,$path
EOF

    # Apply live via IPC: preload → set wallpaper → unload old
    hyprpaper_ipc "preload $path"
    hyprpaper_ipc "wallpaper ,$path"
    hyprpaper_ipc "unload all"
    hyprpaper_ipc "preload $path"  # re-preload after unload all

    echo "Wallpaper: $image"
}

# ── Apply accent live — writes state files and applies via hyprctl ─────
apply_accent() {
    local accent="$1" hex="${ACCENTS[$accent]}"
    mkdir -p "$STATE_DIR"

    # Write state files
    echo -n "$accent" > "$ACCENT_FILE"
    echo -n "$hex" > "$STATE_DIR/current-accent-hex"
    echo "Accent: $accent (#$hex)"

    # Hyprland: apply border colour live via hyprctl keyword
    # (Hyprland 0.55+ uses general:col.active_border, not decoration:col.active_border)
    hyprctl keyword general:col.active_border "rgba(${hex}ff)" 2>/dev/null || true

    # Waybar accent is hardcoded in style.css (Nix store symlink) — needs rebuild to change.
    # We still write waybar-accent.css for future use, but don't reload waybar
    # since CSS @import is not supported by the Waybar CSS parser.
    cat > "$WAYBAR_ACCENT" <<EOF
/* Generated by wallpaper script — do not edit.
 * Waybar CSS parser does not support @import, so this file is not
 * consumed at runtime. Waybar accent is hardcoded in style.css.
 * This file exists for potential future use if @import is supported.
 */
@define-color accent #${hex};
EOF

    echo "Accent applied live (Hyprland borders updated; Waybar needs rebuild)."
}

# ── List available wallpapers ───────────────────────────────────────────
list_wallpapers() {
    find "$WALLPAPER_DIR" -type f \( -name '*.jpg' -o -name '*.png' -o -name '*.jpeg' \) \
        2>/dev/null | sed 's|.*/||' | sort
}

# ── Preview wallpaper colours ───────────────────────────────────────────
preview_wallpaper() {
    local image="$1"
    local path="$WALLPAPER_DIR/$image"
    [ -f "$path" ] || { echo "Not found: $path" >&2; return 1; }

    echo "Wallpaper: $image"
    echo "─────────────────────────────"
    extract_colors "$path" 8 | while read -r hex; do
        printf "\033[48;2;%d;%d;%dm     \033[0m #%s\n" \
            "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}" "$hex"
    done
    echo "─────────────────────────────"
    echo "Best accent: $(best_accent "$image")"
}

# ── Main ─────────────────────────────────────────────────────────────────
case "${1:-}" in
    -h|--help)
        echo "Usage: wallpaper [option] [<image>]"
        echo ""
        echo "  wallpaper               list available wallpapers"
        echo "  wallpaper <image>       set wallpaper + auto-detect accent (live)"
        echo "  wallpaper -r            pick a random wallpaper"
        echo "  wallpaper -l            list available wallpapers"
        echo "  wallpaper -p <image>    preview dominant colours + accent match"
        echo "  wallpaper -h            show this help"
        echo ""
        echo "State files in ~/.config/catppuccin/ — imperative, not git-tracked."
        echo "Hyprland accent is applied live via hyprctl keyword."
        echo "Waybar accent requires a rebuild (hardcoded in style.css)."
        echo "Wallpaper is applied live via hyprpaper IPC (no service restart)."
        exit 0
        ;;
    -l|--list)
        list_wallpapers
        ;;
    -r|--random)
        image=$(list_wallpapers | shuf -n1)
        echo "Random wallpaper: $image"
        set_wallpaper "$image"
        echo -n "$image" > "$WALLPAPER_FILE"

        echo "Detecting best Catppuccin accent..."
        accent=$(best_accent "$image")
        apply_accent "$accent"
        ;;
    -p|--preview)
        preview_wallpaper "${2:?usage: wallpaper -p <image>}"
        ;;
    "")
        list_wallpapers
        ;;
    *)
        image="$1"
        set_wallpaper "$image"
        echo -n "$image" > "$WALLPAPER_FILE"

        echo "Detecting best Catppuccin accent..."
        accent=$(best_accent "$image")
        apply_accent "$accent"
        ;;
esac
