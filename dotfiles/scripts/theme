#!/usr/bin/env bash
# Theme switcher — instant runtime color application.
#   theme                  show current theme
#   theme -l               list curated themes (default: 20 hand-picked)
#   theme -a               list ALL 303 available themes
#   theme -p <name>        preview theme colours in terminal
#   theme -P               interactive bemenu picker (preview + apply)
#   theme <name>           switch to named theme instantly (no rebuild)
#
# Architecture:
#   Declarative: base16-schemes package (the list of available themes)
#   Imperative:   dotfiles/current-theme (active theme, runtime)
#   Templates:    dotfiles/*/{config files} with {{base00}}…{{base0F}} placeholders
#   Generated:    ~/.config/*/{config files} written at theme-switch time

set -e

THEME_FILE="$HOME/dotfiles/current-theme"
CACHE_FILE="$HOME/.cache/base16-themes-path"
CURATED_FILE="$HOME/dotfiles/curated-themes"

# ── Resolve base16-schemes directory ──────────────────────────────────────
if [ -f "$CACHE_FILE" ]; then
    BASE16_DIR=$(cat "$CACHE_FILE")
else
    BASE16_DIR=$(find /nix/store/ -maxdepth 6 -name 'everforest.yaml' -type f 2>/dev/null | head -1 | xargs dirname 2>/dev/null) || true
fi

if [ -z "${BASE16_DIR:-}" ] || [ ! -d "$BASE16_DIR" ]; then
    echo "error: cannot find base16-schemes directory. Is base16-schemes installed?" >&2
    exit 1
fi

# ── Parse a base16 YAML into shell variables base00..base0F ───────────────
parse_yaml() {
    local yaml="$1"
    python3 -c "
import sys, re
with open('$yaml') as f:
    text = f.read()
for i in range(16):
    key = f'base{i:02x}'
    m = re.search(rf'(?i)^\s*{key}:\s*\"?#?([0-9a-fA-F]{{6}})\"?', text, re.MULTILINE)
    if m:
        print(m.group(1))
    else:
        print('ffffff')
" 2>/dev/null
}

# ── Substitute {{base00}}…{{base0F}} and {{xbase00}}…{{xbase0F}} ────────
# Reads template from stdin, writes to stdout.
substitute() {
    local -a c=("$@")  # c[0]=base00, c[1]=base01, ... c[15]=base0F
    local content
    content=$(cat)
    for i in $(seq 0 15); do
        local hex="${c[$i]}"
        local key_lower key_upper
        key_lower=$(printf 'base%02x' "$i")
        key_upper=$(printf 'base%02X' "$i")   # base0A, base0B, ...
        content="${content//"{{${key_lower}}}"/#${hex}}"
        content="${content//"{{${key_upper}}}"/#${hex}}"
        content="${content//"{{x${key_lower}}}"/${hex}}"
        content="${content//"{{x${key_upper}}}"/${hex}}"
    done
    echo "$content"
}

# ── Apply a theme — parse YAML, write configs, reload services ────────────
apply_theme() {
    local theme="$1"
    local yaml="$BASE16_DIR/$theme.yaml"

    if [ ! -f "$yaml" ]; then
        echo "error: theme '$theme' not found at $yaml" >&2
        return 1
    fi

    # Parse colours
    local -a colors
    while IFS= read -r hex; do
        colors+=("$hex")
    done < <(parse_yaml "$yaml")

    if [ ${#colors[@]} -ne 16 ]; then
        echo "error: failed to parse 16 colours from $yaml (got ${#colors[@]})" >&2
        return 1
    fi

    echo "Applying $theme..."

    # Write atomically — .tmp then mv avoids the file-ever-missing gap
    # that triggers Hyprland's autogenerated-config fallback.
    atomic_write() {
        local src="$1" dst="$2"
        mkdir -p "$(dirname "$dst")"
        < "$src" substitute "${colors[@]}" > "$dst.tmp"
        mv "$dst.tmp" "$dst"
    }
    atomic_write "$HOME/dotfiles/hypr/hyprland.conf" "$HOME/.config/hypr/hyprland.conf"
    atomic_write "$HOME/dotfiles/mako/config" "$HOME/.config/mako/config"
    atomic_write "$HOME/dotfiles/waybar/style.css" "$HOME/.config/waybar/style.css"
    atomic_write "$HOME/dotfiles/ghostty/config" "$HOME/.config/ghostty/config"
    atomic_write "$HOME/dotfiles/kitty/kitty.conf" "$HOME/.config/kitty/kitty.conf"
    atomic_write "$HOME/dotfiles/nvim/colors/base16-stylix.vim" "$HOME/.config/nvim/colors/base16-stylix.vim"
    atomic_write "$HOME/dotfiles/yazi/theme.toml" "$HOME/.config/yazi/theme.toml"

    # ── Reload services ──────────────────────────────────────────────────
    hyprctl reload 2>/dev/null || true
    systemctl --user restart waybar.service 2>/dev/null || true
    systemctl --user restart hyprpaper.service 2>/dev/null || true
    makoctl reload 2>/dev/null || true
    # Terminal emulators — SIGUSR1 triggers config reload
    pkill -SIGUSR1 kitty 2>/dev/null || true
    pkill -SIGUSR1 ghostty 2>/dev/null || true
    # Running Neovim instances — reload colourscheme
    shopt -s nullglob 2>/dev/null
    for socket in /tmp/nvim.*/0; do
        [ -S "$socket" ] || continue
        nvim --server "$socket" --remote-send ':colorscheme base16-stylix<CR>' 2>/dev/null || true
    done
    shopt -u nullglob 2>/dev/null

    # Write the theme name to the imperative file
    echo "$theme" > "$THEME_FILE"

    echo "Theme '$theme' applied. GTK/Starship will follow on next nixos-rebuild."
}

# ── Preview a theme in the terminal (ANSI colour swatches) ────────────────
preview_theme() {
    local theme="$1"
    local yaml="$BASE16_DIR/$theme.yaml"

    if [ ! -f "$yaml" ]; then
        echo "error: theme '$theme' not found" >&2
        return 1
    fi

    local -a colors
    while IFS= read -r hex; do
        colors+=("$hex")
    done < <(parse_yaml "$yaml")

    echo "Theme: $theme"
    echo "─────────────────────────────"
    for i in $(seq 0 15); do
        local key label
        key=$(printf 'base%02x' "$i")
        case "$i" in
            0) label="bg        ";;
            1) label="alt-bg    ";;
            2) label="selection ";;
            3) label="comment   ";;
            4) label="subtle    ";;
            5) label="fg        ";;
            6) label="light-fg  ";;
            7) label="brightest ";;
            8) label="red       ";;
            9) label="orange    ";;
            10) label="yellow    ";;
            11) label="green     ";;
            12) label="cyan      ";;
            13) label="blue      ";;
            14) label="purple    ";;
            15) label="brown     ";;
        esac
        printf "\033[48;2;%d;%d;%dm   \033[0m #%s  \033[38;2;%d;%d;%dm%s\033[0m\n" \
            "0x${colors[$i]:0:2}" "0x${colors[$i]:2:2}" "0x${colors[$i]:4:2}" \
            "${colors[$i]}" \
            "0x${colors[$i]:0:2}" "0x${colors[$i]:2:2}" "0x${colors[$i]:4:2}" \
            "$key"
    done
    echo "─────────────────────────────"

    # Detect variant from scheme field
    local variant
    variant=$(rg -N 'scheme:\s*"?(.+?)"?' "$yaml" -r '$1' 2>/dev/null | head -1 || true)
    [ -n "$variant" ] && echo "Scheme: $variant"
}

# ── List all available themes ─────────────────────────────────────────────
list_curated() {
    if [ -f "$CURATED_FILE" ]; then
        \grep -v '^#' "$CURATED_FILE" | \grep -v '^$' || true
    else
        list_all | head -20
    fi
}

list_all() {
    find "$BASE16_DIR" -name '*.yaml' -type f 2>/dev/null | sed 's|.*/||; s|\.yaml$||' | sort
}

# ── Main ──────────────────────────────────────────────────────────────────
case "${1:-}" in
    -l|--list)
        list_curated
        ;;
    -a|--all)
        list_all
        ;;
    -p|--preview)
        if [ -z "${2:-}" ]; then
            echo "usage: theme -p <name>" >&2
            exit 1
        fi
        preview_theme "$2"
        ;;
    -P|--picker)
        choice=$(list_curated | bemenu -l 20 -p "Theme:" 2>/dev/null || true)
        if [ -n "$choice" ]; then
            apply_theme "$choice"
        fi
        ;;
    "")
        cat "$THEME_FILE" 2>/dev/null || echo "unknown"
        ;;
    *)
        apply_theme "$1"
        ;;
esac
