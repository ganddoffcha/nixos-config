#!/usr/bin/env bash
# Theme — stub (Catppuccin Mocha is now the system theme via catppuccin/nix).
# Multi-theme runtime switching has been removed.
# To change Catppuccin flavour or accent, edit home.nix and rebuild.
#
#   theme              show current theme
#   theme -h           show this help

case "${1:-}" in
    -h|--help)
        echo "Usage: theme [option]"
        echo ""
        echo "  theme               show current theme (always catppuccin-mocha)"
        echo "  theme -h            show this help"
        echo ""
        echo "Catppuccin Mocha (blue accent) is the system theme, managed by catppuccin/nix."
        echo "To change flavour or accent, edit ~/home.nix and run 'rebuild'."
        exit 0
        ;;
    -l|-a|-p|-P)
        echo "Theme switching has been migrated to catppuccin/nix." >&2
        echo "Edit ~/home.nix to change catppuccin.flavor or catppuccin.accent, then rebuild." >&2
        exit 1
        ;;
    *)
        echo "catppuccin-mocha"
        ;;
esac
