#!/bin/sh
# NixOS rebuild wrapper — syncs config to /etc/nixos/, rebuilds, then
# commits and pushes the config repo.
#
# Usage: rebuild [action] [-m "commit message"]
#   rebuild                           → nixos-rebuild switch (auto message)
#   rebuild boot                      → nixos-rebuild boot
#   rebuild -m "bemenu: replace wofi" → switch with custom commit message
#   rebuild boot -m "test kernel"     → boot with custom commit message
#
# Managed by home-manager — do not edit directly.

set -eu

REPO_DIR="$HOME"
ETC_DIR="/etc/nixos"
ACTION="switch"
COMMIT_MSG=""

# ── Parse arguments ──────────────────────────────────────────────────

while [ $# -gt 0 ]; do
    case "$1" in
        -m)
            COMMIT_MSG="$2"
            shift 2
            ;;
        switch|boot|test|dry-build|dry-activate|build|dry-build|edit|repl)
            ACTION="$1"
            shift
            ;;
        *)
            echo "Usage: rebuild [switch|boot|test] [-m \"commit message\"]"
            exit 1
            ;;
    esac
done

# ── Sync config files to /etc/nixos/ ─────────────────────────────────

echo "==> Syncing configs to $ETC_DIR ..."
sudo cp -f "$REPO_DIR/configuration.nix" "$ETC_DIR/configuration.nix"
sudo cp -f "$REPO_DIR/home.nix" "$ETC_DIR/home.nix"
sudo cp -rf "$REPO_DIR/dotfiles/"* "$ETC_DIR/dotfiles/"

# ── Rebuild ──────────────────────────────────────────────────────────

echo "==> Running nixos-rebuild $ACTION ..."
sudo nixos-rebuild "$ACTION"

# ── Git commit (only if rebuild succeeded) ────────────────────────────

cd "$REPO_DIR"

# Stage only NixOS config files (avoids accidentally adding nested repos)
git add configuration.nix home.nix dotfiles/ .gitignore

# Only commit if there are changes
if git diff --quiet --cached; then
    echo "==> No config changes to commit."
    exit 0
fi

if [ -n "$COMMIT_MSG" ]; then
    echo "==> Committing: $COMMIT_MSG"
    git commit -m "$COMMIT_MSG"
else
    echo "==> Committing config changes ..."
    git commit -m "nixos-rebuild: $(date +%Y-%m-%d-%H%M)"
fi

# ── Push (non-fatal if no remote or auth fails) ──────────────────────

if git remote -v | grep -q origin; then
    echo "==> Pushing to origin ..."
    git push 2>&1 || echo "==> Push failed (check auth/network) — changes committed locally."
else
    echo "==> No git remote configured — skipping push."
fi
