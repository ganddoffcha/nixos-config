#!/bin/sh
# opout — "open output": open a compiled document's output (usually PDF).
# Usage: opout <file>
#
# Opens the compiled output of a source file:
#   .tex/.md/.rmd/.mom  → PDF in out/ (via zathura)
#   .html               → HTML in browser
#   .sent               → presentation

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
    sed -n '2,9p' "$0" | sed 's/^# //; s/^#$//'
    exit 0
fi

basename="${1%.*}"
name=$(basename "$basename")

case "${*}" in
	*.tex|*.sil|*.m[dse]|*.[rR]md|*.mom|*.[0-9]) target="$(getcomproot "$1" || echo "$1")" ; target_name=$(basename "${target%.*}") ; setsid -f zathura "out/${target_name}".pdf >/dev/null 2>&1 ;;
	*.html) setsid -f "$BROWSER" "$basename".html >/dev/null 2>&1 ;;
	*.sent) setsid -f sent "$1" >/dev/null 2>&1 ;;
esac
